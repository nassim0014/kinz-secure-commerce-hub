# =========================================================
# KINZ Secure Commerce Hub — Environment Variables Template
# Copy this file to `.env` and fill in real values.
# NEVER commit your real .env file.
#
# Generate strong secrets with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#   python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt(rounds=12)).decode())"
# =========================================================

# ---- App ----
NODE_ENV=development
APP_NAME=KINZ Secure Commerce Hub
APP_VERSION=1.0.0
PORT_WEB=3000
PORT_API=8000

# ---- Database ----
POSTGRES_USER=kinz_app
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=kinz_commerce
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://kinz_app:change_me_in_prod@db:5432/kinz_commerce

# ---- Security ----
# JWT_SECRET MUST be >= 32 random bytes. The app refuses to start in
# production if this is set to a known placeholder.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-only-change-me-in-production-please
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_ISSUER=kinz-secure-commerce-hub
JWT_AUDIENCE=kinz-api
BCRYPT_ROUNDS=12
RATE_LIMIT_PER_MINUTE=120
# Comma-separated list. NO wildcards in production.
CORS_ORIGINS=http://localhost:3000,https://kinz.vercel.app

# ---- Demo user (DEV ONLY — set DEMO_USER_ENABLED=false in production) ----
DEMO_USER_ENABLED=true
DEMO_USER_EMAIL=nassim@kinzoils.com
# Generate a real bcrypt hash (60 chars, starts with $2b$12$):
#   python -c "import bcrypt; print(bcrypt.hashpw(b'KINZ-demo-2025!', bcrypt.gensalt(rounds=12)).decode())"
DEMO_USER_PASSWORD_HASH=$2b$12$90JOIYIldwPChFGagj4hPehUSQIRNFzTHmaaRZm9hyAAmqmo/23iG
DEMO_USER_ROLE=admin
DEMO_USER_NAME=Nassim K.

# ---- Audit Logging ----
AUDIT_LOG_PATH=/var/log/kinz/audit.log
AUDIT_LOG_MAX_BYTES=10485760
AUDIT_LOG_BACKUP_COUNT=5
LOG_LEVEL=INFO

# ---- ETL Pipeline ----
ETL_CRON_SCHEDULE=0 2 * * *
ETL_RAW_DIR=/app/data/raw
ETL_PROCESSED_DIR=/app/data/processed

# ---- Optional: Third-party integrations ----
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# STRIPE_SECRET_KEY=
# GOOGLE_ANALYTICS_ID=
