# =========================================================
# KINZ Secure Commerce Hub — Environment Variables Template
# Copy this file to `.env` and fill in real values.
# NEVER commit your real .env file.
# =========================================================

# ---- App ----
NODE_ENV=development
APP_NAME=KINZ Secure Commerce Hub
PORT_WEB=3000
PORT_API=8000

# ---- Database ----
POSTGRES_USER=kinz_app
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=kinz_commerce
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://kinz_app:change_me_in_prod@db:5432/kinz_commerce

# ---- Security ----
JWT_SECRET=replace_with_at_least_32_random_bytes
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
BCRYPT_ROUNDS=12
RATE_LIMIT_PER_MINUTE=120
CORS_ORIGINS=http://localhost:3000,https://kinz.vercel.app

# ---- Audit Logging ----
AUDIT_LOG_PATH=/var/log/kinz/audit.log
LOG_LEVEL=INFO

# ---- ETL Pipeline ----
ETL_CRON_SCHEDULE=0 2 * * *
ETL_RAW_DIR=/app/data/raw
ETL_PROCESSED_DIR=/app/data/processed

# ---- Optional: Third-party integrations ----
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# STRIPE_SECRET_KEY=
# GOOGLE_ANALYTICS_ID=
